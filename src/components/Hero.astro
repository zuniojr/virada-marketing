---
---
<section class="hero" id="inicio">
	<div class="hero-bg">
		<div class="overlay"></div>
		<img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2000&auto=format&fit=crop" alt="Marketing Digital" class="bg-image" />
	</div>

	<div class="container hero-content">
		<div class="hero-text-area animate-fade">
			<div class="badge-premium">
				<span class="dot"></span>
				Agência de Performance
			</div>
			<h1>Aceleramos as vendas da sua empresa com <span class="text-gradient">Alta Conversão</span>.</h1>
			<p>Criação de Landing Pages de alta performance, tráfego pago estratégico e funis de vendas focados em multiplicar o faturamento do seu negócio.</p>
			
			<div class="hero-actions">
				<a href="http://bitlybr.net/virada" class="btn btn-primary" target="_blank" rel="nofollow">
					<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
					Solicitar Orçamento
				</a>
				<a href="#servicos" class="btn btn-outline" target="_blank">Nossas Soluções</a>
			</div>

			<div class="hero-stats">
				<div class="stat-item">
					<span class="stat-value">+500</span>
					<span class="stat-label">Projetos Entregues</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat-item">
					<span class="stat-value">ROI</span>
					<span class="stat-label">Maximizado</span>
				</div>
				<div class="stat-divider"></div>
				<div class="stat-item">
					<span class="stat-value">100%</span>
					<span class="stat-label">Foco em Sucesso</span>
				</div>
			</div>
		</div>

		<div class="hero-visual animate-fade" style="animation-delay: 0.2s;">
			<div class="glass-card trust-card">
				<div class="trust-icon">📈</div>
				<div class="trust-info">
					<h4>Alta Performance</h4>
					<p>Vendas no Automático</p>
				</div>
			</div>
			
			<div class="emergence-pill">
				<div class="pulse"></div>
				Agência Estratégica
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100vh;
		position: relative;
		display: flex;
		align-items: center;
		padding-top: 100px;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
	}

	.bg-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		opacity: 0.4;
	}

	.overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle at 20% 50%, rgba(10, 10, 10, 0.9) 0%, rgba(10, 10, 10, 0.4) 100%);
	}

	.hero-content {
		display: grid;
		grid-template-columns: 1.2fr 0.8fr;
		gap: 60px;
		align-items: center;
		position: relative;
		z-index: 2;
	}

	.badge-premium {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		background: var(--glass);
		border: 1px solid var(--glass-border);
		padding: 8px 20px;
		border-radius: 100px;
		color: var(--primary);
		font-weight: 600;
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-bottom: 25px;
	}

	.dot {
		width: 8px;
		height: 8px;
		background: var(--primary);
		border-radius: 50%;
		box-shadow: 0 0 10px var(--primary);
		animation: pulse 2s infinite;
	}

	@keyframes pulse {
		0% { transform: scale(1); opacity: 1; }
		50% { transform: scale(1.5); opacity: 0.5; }
		100% { transform: scale(1); opacity: 1; }
	}

	.hero h1 {
		font-size: 4.5rem;
		line-height: 1.1;
		margin-bottom: 25px;
	}

	.hero p {
		font-size: 1.2rem;
		color: var(--text-muted);
		max-width: 600px;
		margin-bottom: 45px;
	}

	.hero-actions {
		display: flex;
		gap: 20px;
		margin-bottom: 60px;
	}

	/* Stats */
	.hero-stats {
		display: flex;
		align-items: center;
		gap: 30px;
	}

	.stat-value {
		display: block;
		font-size: 1.8rem;
		font-weight: 800;
		font-family: 'Outfit', sans-serif;
		color: white;
	}

	.stat-label {
		font-size: 0.9rem;
		color: var(--text-muted);
	}

	.stat-divider {
		width: 1px;
		height: 40px;
		background: var(--glass-border);
	}

	/* Visual Elements */
	.hero-visual {
		position: relative;
		display: flex;
		justify-content: center;
	}

	.trust-card {
		display: flex;
		align-items: center;
		gap: 20px;
		max-width: 320px;
		transform: rotate(-3deg);
		animation: float 6s ease-in-out infinite;
	}

	.trust-icon {
		font-size: 2.5rem;
	}

	.trust-info h4 {
		font-size: 1.1rem;
		margin-bottom: 4px;
	}

	.trust-info p {
		font-size: 0.85rem;
		margin-bottom: 0;
	}

	.emergence-pill {
		position: absolute;
		top: -40px;
		right: 20px;
		background: white;
		color: var(--dark);
		padding: 12px 24px;
		border-radius: 100px;
		font-weight: 800;
		display: flex;
		align-items: center;
		gap: 12px;
		box-shadow: 0 15px 40px rgba(0,0,0,0.3);
		transform: rotate(5deg);
	}

	@keyframes float {
		0%, 100% { transform: translateY(0) rotate(-3deg); }
		50% { transform: translateY(-20px) rotate(-1deg); }
	}

	@media (max-width: 1200px) {
		.hero h1 { font-size: 3.5rem; }
	}

	@media (max-width: 992px) {
		.hero-content {
			grid-template-columns: 1fr;
			text-align: center;
		}
		.hero-bg {
			opacity: 0.6;
		}
		.overlay {
			background: radial-gradient(circle, rgba(10, 10, 10, 0.95) 0%, rgba(10, 10, 10, 0.7) 100%);
		}
		.badge-premium, .hero-actions, .hero-stats {
			justify-content: center;
		}
		.hero p { margin: 0 auto 45px; }
		.hero-visual { display: none; }
	}

	@media (max-width: 768px) {
		.hero h1 { font-size: 2.8rem; }
		.hero-actions { flex-direction: column; }
		.hero-stats {
			flex-wrap: wrap;
			gap: 20px;
		}
	}
</style>
