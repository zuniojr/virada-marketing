---
const services = [
  {
    title: 'Criação de Landing Pages',
    description: 'Páginas focadas em conversão, com copy persuasiva e design premium para captar leads e gerar vendas.',
    icon: '💻',
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Gestão de Tráfego',
    description: 'Anúncios estratégicos no Google e Meta Ads para colocar sua oferta de frente para o público ideal.',
    icon: '🎯',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Posicionamento Social',
    description: 'Gestão de conteúdo qualificado e estratégico nas principais redes para construção de autoridade.',
    icon: '📱',
    image: 'https://images.unsplash.com/photo-1611162617474-5b21e879e113?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'SEO e Automação',
    description: 'Otimização orgânica (SEO) e automação de fluxos de e-mail para nutrição automática de leads.',
    icon: '⚙️',
    image: 'https://images.unsplash.com/photo-1572177812156-58036aae439c?q=80&w=800&auto=format&fit=crop'
  }
];
---

<section id="servicos" class="services">
	<div class="container">
		<div class="section-header animate-fade">
			<span class="section-badge">Nossas Soluções</span>
			<h2>Serviços de <span class="text-gradient">Alta Conversão</span></h2>
			<p>Estratégias digitais de ponta a ponta para construir sua máquina de vendas previsível.</p>
		</div>
		
		<div class="services-grid">
			{services.map((service, index) => (
				<div class="service-card glass-card animate-fade" style={`animation-delay: ${0.1 * index}s`}>
					<div class="card-visual">
						<img src={service.image} alt={service.title} />
						<div class="card-icon-wrapper">{service.icon}</div>
					</div>
					<div class="card-info">
						<h3>{service.title}</h3>
						<p>{service.description}</p>
						<a href="https://wa.me/5547999999999" class="service-link">
							Solicitar Orçamento 
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
						</a>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.services {
		padding: 120px 0;
		background: var(--dark-surface);
		position: relative;
	}

	.section-header {
		text-align: center;
		max-width: 700px;
		margin: 0 auto 60px;
	}

	.section-badge {
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
		margin-bottom: 15px;
		display: block;
	}

	.section-header h2 {
		font-size: 3rem;
		margin-bottom: 20px;
	}

	.section-header p {
		color: var(--text-muted);
		font-size: 1.1rem;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 30px;
	}

	.service-card {
		padding: 0;
		overflow: hidden;
	}

	.card-visual {
		position: relative;
		height: 200px;
		overflow: hidden;
	}

	.card-visual img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: var(--transition);
	}

	.service-card:hover .card-visual img {
		transform: scale(1.1);
	}

	.card-icon-wrapper {
		position: absolute;
		bottom: -25px;
		right: 25px;
		background: var(--primary);
		width: 50px;
		height: 50px;
		border-radius: 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.5rem;
		box-shadow: 0 10px 20px var(--primary-glow);
		z-index: 2;
	}

	.card-info {
		padding: 40px 30px 30px;
	}

	.card-info h3 {
		font-size: 1.4rem;
		margin-bottom: 15px;
	}

	.card-info p {
		color: var(--text-muted);
		font-size: 0.95rem;
		margin-bottom: 25px;
		height: 4.8em;
		overflow: hidden;
	}

	.service-link {
		color: var(--primary);
		text-decoration: none;
		font-weight: 700;
		font-size: 0.9rem;
		display: inline-flex;
		align-items: center;
		gap: 10px;
		transition: var(--transition);
	}

	.service-link:hover {
		gap: 15px;
	}

	@media (max-width: 768px) {
		.section-header h2 { font-size: 2.2rem; }
		.services { padding: 80px 0; }
	}
</style>
