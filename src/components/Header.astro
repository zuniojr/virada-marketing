---
---
<header class="main-header" id="header">
	<div class="container header-inner">
		<!-- Logo Area -->
		<a href="/" class="logo">
			<span class="logo-icon">🚀</span>
			<div class="logo-text">
				<span class="brand">Virada <span class="text-gradient">Marketing</span></span>
				<span class="tagline">Digital</span>
			</div>
		</a>

		<!-- Navigation -->
		<nav class="nav-desktop">
			<ul class="nav-links">
				<li><a href="/">Início</a></li>
				<li><a href="/servicos">Serviços</a></li>
				<li><a href="/sobre">Agência</a></li>
				<li><a href="/blog">Blog</a></li>
				<li><a href="/contato">Contato</a></li>
			</ul>
		</nav>

		<!-- CTA -->
		<div class="header-cta">
			<a href="https://wa.me/5547999999999" class="btn btn-primary btn-sm">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
				<span>(47) 99999-9999</span>
			</a>
			<button class="mobile-menu-toggle" id="menuToggle" aria-label="Abrir Menu">
				<span></span>
				<span></span>
			</button>
		</div>
	</div>

	<!-- Mobile Menu Overlay -->
	<div class="mobile-menu" id="mobileMenu">
		<nav>
			<ul>
				<li><a href="/">Início</a></li>
				<li><a href="/servicos">Serviços</a></li>
				<li><a href="/sobre">Agência</a></li>
				<li><a href="/blog">Blog</a></li>
				<li><a href="/contato">Contato</a></li>
			</ul>
		</nav>
		<div class="mobile-cta">
			<a href="https://wa.me/5547999999999" class="btn btn-primary w-full">Solicitar Orçamento</a>
		</div>
	</div>
</header>

<style>
	.main-header {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		z-index: 1000;
		background: rgba(10, 10, 10, 0.6);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border-bottom: 1px solid var(--glass-border);
		transition: var(--transition);
		padding: 15px 0;
	}

	.main-header.scrolled {
		padding: 10px 0;
		background: rgba(10, 10, 10, 0.95);
	}

	.header-inner {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	/* Logo */
	.logo {
		text-decoration: none;
		display: flex;
		align-items: center;
		gap: 12px;
	}

	.logo-icon {
		font-size: 1.8rem;
		filter: drop-shadow(0 0 10px var(--primary-glow));
	}

	.logo-text {
		display: flex;
		flex-direction: column;
	}

	.brand {
		color: white;
		font-size: 1.3rem;
		font-weight: 800;
		font-family: 'Outfit', sans-serif;
		line-height: 1;
	}

	.tagline {
		color: var(--text-muted);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		margin-top: 2px;
	}

	/* Desktop Nav */
	.nav-desktop {
		background: var(--glass);
		border: 1px solid var(--glass-border);
		border-radius: 100px;
		padding: 5px 25px;
	}

	.nav-links {
		display: flex;
		list-style: none;
		gap: 30px;
	}

	.nav-links a {
		color: var(--text-muted);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: var(--transition);
	}

	.nav-links a:hover, .nav-links a.active {
		color: var(--primary);
	}

	/* CTA */
	.header-cta {
		display: flex;
		align-items: center;
		gap: 20px;
	}

	.btn-sm {
		padding: 10px 20px;
		font-size: 0.9rem;
	}

	/* Mobile Toggle */
	.mobile-menu-toggle {
		display: none;
		flex-direction: column;
		gap: 6px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 5px;
	}

	.mobile-menu-toggle span {
		display: block;
		width: 25px;
		height: 2px;
		background: white;
		transition: var(--transition);
	}

	/* Mobile Menu */
	.mobile-menu {
		position: fixed;
		top: 0;
		right: -100%;
		width: 100%;
		height: 100vh;
		background: var(--dark);
		padding: 100px 40px;
		display: flex;
		flex-direction: column;
		gap: 40px;
		transition: 0.5s cubic-bezier(0.4, 0, 0.2, 1);
		z-index: 999;
	}

	.mobile-menu.active {
		right: 0;
	}

	.mobile-menu ul {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 25px;
	}

	.mobile-menu a {
		color: white;
		text-decoration: none;
		font-size: 2rem;
		font-family: 'Outfit', sans-serif;
		font-weight: 700;
	}

	.w-full {
		width: 100%;
	}

	@media (max-width: 992px) {
		.nav-desktop {
			display: none;
		}
		.mobile-menu-toggle {
			display: flex;
		}
	}
</style>

<script>
	const header = document.getElementById('header');
	const menuToggle = document.getElementById('menuToggle');
	const mobileMenu = document.getElementById('mobileMenu');

	window.addEventListener('scroll', () => {
		if (window.scrollY > 50) {
			header.classList.add('scrolled');
		} else {
			header.classList.remove('scrolled');
		}
	});

	menuToggle.addEventListener('click', () => {
		mobileMenu.classList.toggle('active');
		const spans = menuToggle.querySelectorAll('span');
		spans[0].style.transform = mobileMenu.classList.contains('active') ? 'rotate(45deg) translate(6px, 6px)' : 'none';
		spans[1].style.transform = mobileMenu.classList.contains('active') ? 'rotate(-45deg) translate(1px, -2px)' : 'none';
	});
</script>
</style>
