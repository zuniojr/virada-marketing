---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = "Abertura de Portas 24 Horas - Chaveiro Itajaí";
const description = "Emergência? Abro sua porta residencial ou comercial sem danificar a fechadura. Atendimento rápido em toda a região litoral.";
---

<Layout title={title} description={description}>
	<Header />
	<main class="service-page">
		<div class="page-header">
			<div class="container">
				<h1>Abertura de Portas</h1>
				<p>Destrancamento de portas residenciais e comerciais 24h por dia.</p>
			</div>
		</div>
		
		<div class="container content">
			<h2>Ficou para o lado de fora?</h2>
			<p>Esqueceu a chave dentro de casa ou perdeu na rua? Nossa equipe especializada chega até você em minutos. Realizamos a abertura da sua porta com ferramentas adequadas, evitando danos permanentes a maçanetas e fechaduras para que seu prejuízo seja o mínimo possível.</p>
			
			<div class="cta-box text-center mt-10">
				<h3>Socorro Imediato 24h</h3>
				<a href="https://wa.me/5547999999999" class="btn btn-primary btn-large">Chamar no WhatsApp Urgente</a>
			</div>
		</div>
	</main>
	<Footer />
</Layout>

<style>
	.page-header { background: #1a1a1a; color: white; padding: 100px 0 60px; text-align: center; }
	.page-header h1 { font-size: 2.5rem; margin-bottom: 10px; color: var(--primary); }
	.page-header p { font-size: 1.2rem; color: #ccc; }
	.content { padding: 60px 20px; max-width: 800px; margin: 0 auto; line-height: 1.8; }
	.content h2 { margin-bottom: 20px; font-size: 1.8rem; }
	.content p { font-size: 1.1rem; color: #444; margin-bottom: 20px; }
	.cta-box { background: #f9f9f9; padding: 40px; border-radius: 8px; border-top: 4px solid var(--primary); margin-top: 50px; }
	.cta-box h3 { margin-bottom: 25px; }
	.text-center { text-align: center; }
</style>
