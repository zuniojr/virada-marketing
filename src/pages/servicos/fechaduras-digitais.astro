---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = "Fechaduras Digitais e Eletrônicas - Chaveiro Itajaí";
const description = "Instalação e manutenção de fechaduras digitais, biométricas e com senha. Modernidade e segurança para seu imóvel.";
---

<Layout title={title} description={description}>
	<Header />
	<main class="service-page">
		<div class="page-header">
			<div class="container">
				<h1>Fechaduras Digitais</h1>
				<p>Tecnologia e Segurança de ponta para a sua casa ou escritório.</p>
			</div>
		</div>
		
		<div class="container content">
			<h2>Modernize o seu acesso</h2>
			<p>Esqueça as chaves físicas! As fechaduras digitais oferecem acesso rápido e seguro através de senha, biometria (impressão digital), cartão ou aplicativo no celular. Ideal para donos de imóveis de temporada (Airbnb) e escritórios modernos.</p>
			
			<div class="cta-box text-center mt-10">
				<h3>Quer um orçamento para Fechadura Eletrônica?</h3>
				<a href="https://wa.me/5547999999999" class="btn btn-primary btn-large">Falar com Especialista</a>
			</div>
		</div>
	</main>
	<Footer />
</Layout>

<style>
	.page-header { background: #1a1a1a; color: white; padding: 100px 0 60px; text-align: center; }
	.page-header h1 { font-size: 2.5rem; margin-bottom: 10px; color: var(--primary); }
	.page-header p { font-size: 1.2rem; color: #ccc; }
	.content { padding: 60px 20px; max-width: 800px; margin: 0 auto; line-height: 1.8; }
	.content h2 { margin-bottom: 20px; font-size: 1.8rem; }
	.content p { font-size: 1.1rem; color: #444; margin-bottom: 20px; }
	.cta-box { background: #f9f9f9; padding: 40px; border-radius: 8px; border-top: 4px solid var(--primary); margin-top: 50px; }
	.cta-box h3 { margin-bottom: 25px; }
	.text-center { text-align: center; }
</style>
