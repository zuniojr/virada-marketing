---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Footer from '../components/Footer.astro';

const title = "Virada Marketing Digital | Agência de Alta Performance";
const description = "Aceleramos as vendas do seu negócio com Landing Pages de alta conversão, gestão de tráfego pago e estratégias digitais.";
---

<Layout title={title} description={description}>
	<Header />
	<main>
		<Hero />
		<Services />
		
		<section id="sobre" class="about">
			<div class="container about-inner">
				<div class="about-image animate-fade">
					<img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=1200&auto=format&fit=crop" alt="Equipe de Maketing Digital Criativa" />
					<div class="experience-badge">
						<span class="exp-years">10X</span>
						<span class="exp-text">Mais Resultados</span>
					</div>
				</div>
				<div class="about-text animate-fade" style="animation-delay: 0.2s;">
					<span class="section-badge">A Agência</span>
					<h2>Metodologia Baseada em <span class="text-gradient">Dados e Conversão</span></h2>
					<p>Nós não fazemos apenas "posts bonitinhos". Criamos estruturas digitais robustas desenhadas exclusivamente para transformar visitantes em clientes compradores para o seu negócio.</p>
					
					<div class="benefits-list">
						<div class="benefit-item">
							<span class="benefit-icon">🚀</span>
							<div class="benefit-content">
								<h4>Design Direcionado</h4>
								<p>Landing Pages criadas com Copywriting e UX design para máxima captação.</p>
							</div>
						</div>
						<div class="benefit-item">
							<span class="benefit-icon">🎯</span>
							<div class="benefit-content">
								<h4>Tráfego Qualificado</h4>
								<p>Campanhas otimizadas diariamente para reduzir o custo por aquisição.</p>
							</div>
						</div>
						<div class="benefit-item">
							<span class="benefit-icon">📊</span>
							<div class="benefit-content">
								<h4>Escala Previsível</h4>
								<p>Análise de métricas claras para você saber exatamente o retorno sobre o investimento.</p>
							</div>
						</div>
					</div>

					<a href="https://wa.me/5547999999999" class="btn btn-primary">Agendar Sessão Estratégica</a>
				</div>
			</div>
		</section>
		
		<section id="consultoria" class="emergency-cta">
			<div class="container">
				<div class="glass-card emergency-box animate-fade">
					<div class="emergency-content">
						<h2>Pronto para assumir o controle das suas vendas?</h2>
						<p>Pare de depender apenas de indicações. Construa hoje a estrutura de marketing do seu negócio.</p>
						<div class="emergency-actions">
							<a href="https://wa.me/5547999999999" class="btn btn-primary btn-large">
								🚀 Falar com a Equipe
							</a>
							<span class="emergency-note">Vagas limitadas para novos projetos neste mês.</span>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />

	<a href="https://wa.me/5547999999999" class="whatsapp-float" target="_blank" aria-label="WhatsApp">
		<svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12.031 2c-5.511 0-9.997 4.486-9.997 9.998 0 1.761.458 3.413 1.258 4.851l-1.337 4.887 4.996-1.312c1.406.768 3.004 1.21 4.708 1.21 5.51 0 9.995-4.486 9.995-9.998 0-5.512-4.485-9.998-9.995-9.998zm0 1.5c4.685 0 8.496 3.81 8.496 8.498 0 4.686-3.811 8.498-8.496 8.498-1.503 0-2.914-.393-4.14-1.077l-.297-.165-2.973.781.799-2.923-.182-.289c-.732-1.168-1.163-2.553-1.163-4.032.001-4.688 3.812-8.498 8.496-8.498zm-3.649 3.256c-.198 0-.462.073-.704.331-.243.258-.928.906-.928 2.208s.948 2.562 1.08 2.741c.132.178 1.867 2.85 4.522 3.996.632.272 1.125.435 1.509.557.635.202 1.213.174 1.669.107.509-.074 1.564-.638 1.786-1.257.221-.617.221-1.147.155-1.257-.066-.111-.242-.178-.508-.312s-1.564-.771-1.808-.859c-.243-.088-.419-.133-.596.133s-.685.859-.839 1.036c-.155.178-.309.2-.575.067-.265-.133-1.121-.413-2.135-1.319-.789-.702-1.321-1.569-1.476-1.834-.155-.265-.016-.409.117-.541.12-.119.265-.311.398-.466.133-.155.177-.266.265-.443.088-.178.044-.333-.022-.466-.066-.133-.596-1.33-.817-1.868-.216-.527-.456-.456-.63-.464z"/></svg>
	</a>
</Layout>

<style>
	/* About Section */
	.about {
		padding: 120px 0;
		background: var(--dark);
	}

	.about-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 80px;
		align-items: center;
	}

	.about-image {
		position: relative;
	}

	.about-image img {
		width: 100%;
		border-radius: 24px;
		box-shadow: 0 30px 60px rgba(0,0,0,0.5);
	}

	.experience-badge {
		position: absolute;
		bottom: -30px;
		right: -30px;
		background: var(--primary);
		padding: 30px;
		border-radius: 24px;
		text-align: center;
		box-shadow: 0 20px 40px var(--primary-glow);
		color: var(--dark);
	}

	.exp-years {
		display: block;
		font-size: 2.5rem;
		font-weight: 800;
		line-height: 1;
	}

	.exp-text {
		font-size: 0.9rem;
		font-weight: 700;
		text-transform: uppercase;
	}

	.section-badge {
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		font-size: 0.85rem;
		margin-bottom: 15px;
		display: block;
	}

	.about-text h2 {
		font-size: 3rem;
		margin-bottom: 25px;
		line-height: 1.2;
	}

	.about-text p {
		color: var(--text-muted);
		font-size: 1.1rem;
		margin-bottom: 40px;
	}

	.benefits-list {
		display: flex;
		flex-direction: column;
		gap: 30px;
		margin-bottom: 50px;
	}

	.benefit-item {
		display: flex;
		gap: 20px;
	}

	.benefit-icon {
		font-size: 1.8rem;
		flex-shrink: 0;
	}

	.benefit-content h4 {
		font-size: 1.2rem;
		margin-bottom: 5px;
	}

	.benefit-content p {
		font-size: 0.95rem;
		margin-bottom: 0;
	}

	/* Emergency Section */
	.emergency-cta {
		padding: 60px 0 120px;
	}

	.emergency-box {
		padding: 80px 40px;
		text-align: center;
		background: linear-gradient(135deg, rgba(255, 215, 0, 0.05) 0%, rgba(255, 255, 255, 0.02) 100%);
	}

	.emergency-box h2 {
		font-size: 2.5rem;
		margin-bottom: 20px;
	}

	.emergency-box p {
		font-size: 1.2rem;
		color: var(--text-muted);
		margin-bottom: 40px;
	}

	.emergency-actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 20px;
	}

	.btn-large {
		padding: 20px 45px;
		font-size: 1.2rem;
	}

	.emergency-note {
		font-size: 0.9rem;
		color: var(--text-muted);
	}

	@media (max-width: 992px) {
		.about-inner {
			grid-template-columns: 1fr;
			gap: 60px;
			text-align: center;
		}
		.about-image {
			order: 2;
			max-width: 600px;
			margin: 0 auto;
		}
		.experience-badge {
			right: 20px;
			bottom: 20px;
			padding: 20px;
		}
		.benefits-list {
			text-align: left;
		}
	}

	@media (max-width: 768px) {
		.about-text h2 { font-size: 2rem; }
		.emergency-box h2 { font-size: 1.8rem; }
	}
</style>
