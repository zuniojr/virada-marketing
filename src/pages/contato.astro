---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Contato | Fale com a Virada Marketing Digital";
const description = "Entre em contato conosco para acelerar as vendas do seu negócio com especialistas em performance.";

const contactItems = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="32" height="32" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.888-.788-1.489-1.761-1.663-2.06-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>',
    title: '',
    value: 'WhatsApp',
    link: 'http://bitlybr.net/virada',
    subtitle: 'Falar com Especialistas'
  },
  {
    icon: '📧',
    title: 'E-mail Comercial',
    value: 'contato@viradamarketing.com.br',
    link: 'mailto:contato@viradamarketing.com.br',
    subtitle: 'Retorno em até 24 horas úteis'
  },
  {
    icon: '📍',
    title: 'Nossa Base',
    value: 'Itajaí - Centro / SC',
    link: '#mapa',
    subtitle: 'Atendendo toda a AMFRI'
  }
];
---

<Layout title={title} description={description}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container animate-fade">
				<span class="section-badge">Próximo Nível</span>
				<h1>Fale <span class="text-gradient">Conosco</span></h1>
				<p>Pronto para escalar sua empresa? Preencha o formulário ou chame no WhatsApp para uma análise gratuita do seu negócio.</p>
			</div>
		</section>

		<section class="contact-section">
			<div class="container">
				<div class="contact-methods animate-fade">
					{contactItems.map(item => (
						<a href={item.link} class="glass-card contact-item" target="_blank" rel="nofollow">
							<div class="item-icon" set:html={item.icon}></div>
							<div class="item-text">
								{item.title && <h3>{item.title}</h3>}
								<span class="item-value" style={item.value === 'WhatsApp' ? 'font-size: 1.8rem;' : ''}>{item.value}</span>
								<span class="item-subtitle">{item.subtitle}</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="map-section animate-fade" id="mapa">
			<div class="container">
				<div class="map-container glass-card">
					<div class="map-placeholder">
						<h3>Escala Global</h3>
						<p>Atendemos clientes em todo o Brasil e no exterior com operações 100% digitais, mantendo nossa base de inteligência estratégica em Itajaí/SC.</p>
						<span class="coverage-badge">🌎 Sem fronteiras para o crescimento</span>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding: 200px 0 100px;
		background: var(--dark-surface);
		text-align: center;
		border-bottom: 1px solid var(--glass-border);
	}

	.page-hero h1 {
		font-size: 4rem;
		margin-bottom: 20px;
	}

	.page-hero p {
		font-size: 1.2rem;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto;
	}

	.contact-section {
		padding: 120px 0;
	}

	.contact-grid {
		display: grid;
		grid-template-columns: 0.8fr 1.2fr;
		gap: 60px;
		align-items: flex-start;
	}

	.contact-methods {
		display: grid;
		gap: 20px;
	}

	.contact-item {
		display: flex;
		padding: 30px;
		gap: 25px;
		text-decoration: none;
		align-items: center;
		transition: var(--transition);
	}

	.contact-item:hover {
		border-color: var(--primary);
		transform: scale(1.02);
	}

	.item-icon {
		font-size: 2rem;
		background: rgba(255, 215, 0, 0.1);
		width: 60px;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 15px;
		flex-shrink: 0;
	}

	.item-text h3 {
		font-size: 1rem;
		color: var(--text-muted);
		margin-bottom: 5px;
		font-weight: 500;
	}

	.item-value {
		display: block;
		font-size: 1.3rem;
		font-weight: 800;
		color: white;
		line-height: 1.2;
		margin-bottom: 4px;
	}

	.item-subtitle {
		font-size: 0.85rem;
		color: var(--primary);
		font-weight: 700;
		text-transform: uppercase;
	}

	.contact-form-area {
		padding: 60px;
	}

	.contact-form-area h2 {
		font-size: 2.2rem;
		margin-bottom: 40px;
	}

	.form-row {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 25px;
	}

	.form-group {
		margin-bottom: 25px;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	.form-group label {
		font-size: 0.95rem;
		font-weight: 700;
		color: white;
	}

	.form-group input, .form-group select, .form-group textarea {
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid var(--glass-border);
		padding: 15px 20px;
		border-radius: 12px;
		color: white;
		font-size: 1rem;
		width: 100%;
	}

	.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
		outline: none;
		border-color: var(--primary);
	}

	.map-section {
		padding-bottom: 150px;
	}

	.map-container {
		height: 400px;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #121212 0%, #0A0A0A 100%);
		text-align: center;
		padding: 40px;
	}

	.coverage-badge {
		display: inline-block;
		margin-top: 25px;
		background: var(--primary);
		color: var(--dark);
		padding: 8px 25px;
		border-radius: 100px;
		font-weight: 800;
		text-transform: uppercase;
		font-size: 0.85rem;
	}

	.w-full { width: 100%; }

	@media (max-width: 992px) {
		.contact-grid { grid-template-columns: 1fr; }
		.page-hero h1 { font-size: 3rem; }
	}

	@media (max-width: 768px) {
		.form-row { grid-template-columns: 1fr; }
		.contact-form-area { padding: 40px 25px; }
	}
</style>
