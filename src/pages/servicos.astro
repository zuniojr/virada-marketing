---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = "Soluções Digitais | Virada Marketing Digital";
const description = "Conheça nossas soluções completas para escalar seu negócio: criação de landing pages, gestão de tráfego, social media e SEO.";

const allServices = [
  {
    title: 'Criação de Landing Pages',
    description: 'Desenvolvemos páginas otimizadas para conversão com design premium, copywriting persuasivo e carregamento ultrarrápido.',
    features: ['Design focado em UX/UI', 'Copywriting estratégico', 'Alta velocidade de carregamento', 'Integração com CRM e pixels'],
    icon: '💻',
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Gestão de Tráfego',
    description: 'Campanhas de alta performance no Google Ads, Meta Ads e TikTok Ads para colocar sua oferta de frente com quem quer comprar.',
    features: ['Análise de público-alvo', 'Criação de anúncios criativos', 'Otimização diária de campanhas', 'Relatórios transparentes de ROI'],
    icon: '🎯',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Posicionamento Social',
    description: 'Construa autoridade e engajamento genuíno com seu público nas redes que mais importam para o seu segmento.',
    features: ['Calendário editorial estratégico', 'Criação de conteúdo visual', 'Gestão de engajamento', 'Análise de métricas'],
    icon: '📱',
    image: 'https://images.unsplash.com/photo-1611162617474-5b21e879e113?q=80&w=800&auto=format&fit=crop'
  },
  {
    title: 'Consultoria e Estratégia',
    description: 'Um direcionamento completo de marketing e vendas desenhado especificamente para a realidade atual do seu negócio.',
    features: ['Diagnóstico completo de presença online', 'Planejamento de funil de vendas', 'Mapeamento de concorrentes', 'Acompanhamento de implementação'],
    icon: '📈',
    image: 'https://images.unsplash.com/photo-1552664730-d307ca884978?q=80&w=800&auto=format&fit=crop'
  }
];
---

<Layout title={title} description={description}>
	<Header />
	<main>
		<section class="page-hero">
			<div class="container animate-fade">
				<span class="section-badge">Metodologia Virada</span>
				<h1>Nossas <span class="text-gradient">Soluções</span></h1>
				<p>Estratégias digitais de ponta a ponta para construir sua máquina de vendas previsível.</p>
			</div>
		</section>

		<section class="services-detail">
			<div class="container">
				{allServices.map((service, index) => (
					<div class={`service-block ${index % 2 !== 0 ? 'reverse' : ''}`}>
						<div class="service-content animate-fade">
							<div class="service-icon">{service.icon}</div>
							<h2>{service.title}</h2>
							<p>{service.description}</p>
							<ul class="feature-list">
								{service.features.map(feature => (
									<li>
										<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
										{feature}
									</li>
								))}
							</ul>
							<a href="http://bitlybr.net/virada" class="btn btn-primary" target="_blank" rel="nofollow">Solicitar este Serviço</a>
						</div>
						<div class="service-visual animate-fade" style="animation-delay: 0.2s;">
							<img src={service.image} alt={service.title} />
						</div>
					</div>
				))}
			</div>
		</section>

		<section class="cta-banner">
			<div class="container">
				<div class="glass-card animate-fade">
					<h2>Pronto para iniciar seu projeto?</h2>
					<p>Cada negócio é único. Converse com um de nossos especialistas para criarmos um plano de ação sob medida para escalar suas vendas.</p>
					<a href="http://bitlybr.net/virada" class="btn btn-outline" target="_blank" rel="nofollow">Agendar Consultoria Gratuita</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<style>
	.page-hero {
		padding: 200px 0 100px;
		background: var(--dark-surface);
		text-align: center;
		border-bottom: 1px solid var(--glass-border);
	}

	.page-hero h1 {
		font-size: 4rem;
		margin-bottom: 20px;
	}

	.page-hero p {
		font-size: 1.2rem;
		color: var(--text-muted);
		max-width: 600px;
		margin: 0 auto;
	}

	.services-detail {
		padding: 120px 0;
	}

	.service-block {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 100px;
		align-items: center;
		margin-bottom: 150px;
	}

	.service-block.reverse .service-content { order: 2; }
	.service-block.reverse .service-visual { order: 1; }

	.service-icon {
		font-size: 3rem;
		margin-bottom: 25px;
		display: block;
	}

	.service-content h2 {
		font-size: 2.5rem;
		margin-bottom: 20px;
	}

	.service-content p {
		font-size: 1.1rem;
		color: var(--text-muted);
		margin-bottom: 35px;
		line-height: 1.8;
	}

	.feature-list {
		list-style: none;
		margin-bottom: 40px;
		display: grid;
		gap: 15px;
	}

	.feature-list li {
		display: flex;
		align-items: center;
		gap: 12px;
		font-weight: 600;
		color: #fff;
	}

	.service-visual img {
		width: 100%;
		border-radius: 30px;
		box-shadow: 0 40px 80px rgba(0,0,0,0.5);
	}

	.cta-banner {
		padding-bottom: 150px;
	}

	.cta-banner .glass-card {
		padding: 80px 40px;
		text-align: center;
	}

	.cta-banner h2 { font-size: 2.5rem; margin-bottom: 20px; }
	.cta-banner p { color: var(--text-muted); font-size: 1.1rem; margin-bottom: 40px; max-width: 700px; margin-inline: auto; }

	@media (max-width: 992px) {
		.service-block {
			grid-template-columns: 1fr;
			gap: 60px;
			text-align: center;
		}
		.service-block.reverse .service-content { order: 1; }
		.service-block.reverse .service-visual { order: 2; }
		.feature-list { justify-content: center; text-align: left; }
		.page-hero h1 { font-size: 3rem; }
	}
</style>
